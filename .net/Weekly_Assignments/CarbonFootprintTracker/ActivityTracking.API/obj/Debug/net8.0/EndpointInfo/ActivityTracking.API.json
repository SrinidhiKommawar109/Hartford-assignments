{
  "openapi": "3.0.1",
  "info": {
    "title": "Activity Tracking API",
    "version": "v1"
  },
  "paths": {
    "/api/Activity/transport": {
      "post": {
        "tags": [
          "Activity"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransportRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/TransportRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/TransportRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Activity/energy": {
      "post": {
        "tags": [
          "Activity"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EnergyRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EnergyRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EnergyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Activity/waste": {
      "post": {
        "tags": [
          "Activity"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WasteRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/WasteRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/WasteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EnergyRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "nullable": true
          },
          "unitsConsumed": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "TransportRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "nullable": true
          },
          "transportMode": {
            "type": "string",
            "nullable": true
          },
          "distanceKm": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "WasteRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "nullable": true
          },
          "weightKg": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "JWT Authorization header using the Bearer scheme. Example: \"Authorization: Bearer {token}\"",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}